      "boundElements": [],
      "updated": 1773768478928,
      "link": null,
      "locked": false,
      "text": "Input-Context : vector of 36 numbers representing\ndemand supply congestion for the next hour\n\nOutput - Action : selects action with highest\nexpected reward\n\nExploration strategy - 90% of the time: Pick the\nbest known action.10% of the time: Try a random\naction to see if we find a better strategy.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "DRqYWdIulTFR8geIC3w76",
      "originalText": "Input-Context : vector of 36 numbers representing demand supply congestion for the next hour\n\nOutput - Action : selects action with highest expected reward\n\nExploration strategy - 90% of the time: Pick the best known action.10% of the time: Try a random action to see if we find a better strategy.",
      "autoResize": true,
      "lineHeight": 1.25
    },
